# Primary intent input can also be passed from CLI.
INTENT=

# MongoDB URI (required in this repo's env).
MONGODB_URI=
MONGODB_DB=web_crawler
MONGODB_RUNS_COLLECTION=ie_runs
MONGODB_URL_SUMMARIES_COLLECTION=ie_url_summaries
MONGODB_EVENTS_COLLECTION=ie_events

# Query/search keys
GOOGLE_API_KEY=
GOOGLE_API_KEYS=
GOOGLE_SEARCH_ENGINE_ID=
SEARCH_QUERY_CONCURRENCY=8
SEARCH_RETRY_ATTEMPTS=4
SEARCH_RETRY_BASE_BACKOFF_SECONDS=1.0
SEARCHAPI_API_KEY=

# LLM config (Gemini is used by internet-explorer normal agent path).
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3-flash-preview

# Optional Azure config (still used by some eu-swarm planner/provider paths).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL=gpt-4.1

# Browser delegation config
# Optional local checkout path fallback; not needed when eu-swarm is installed as package.
EU_SWARM_PATH=../eu-swarm
BROWSER_MODE=chromium
BROWSER_HEADED=false
BROWSER_CHROMIUM_SANDBOX=false
ENABLE_BROWSER_DELEGATION=true

# Temp credentials for signup attempts
TEMP_GOOGLE_EMAIL=
TEMP_GOOGLE_PASSWORD=
TEMP_SIGNUP_EMAIL=
TEMP_SIGNUP_PASSWORD=

# Baseline novelty file (one domain per line)
BASELINE_DOMAINS_FILE=data/tool_flow_baseline_domains.txt
KNOWN_TOOLS_FILE=data/known_tools.txt

# Candidate source start mode:
# - domain_homepage: evaluate one unique registrable domain and start from its homepage
# - first_result_url: evaluate one unique registrable domain but start from the first SERP URL seen
CANDIDATE_START_MODE=first_result_url

# Browser concurrency cap: 0 means unlimited.
MAX_BROWSER_CONCURRENCY=0
# Hard timeout for each delegated browser task.
BROWSER_DELEGATE_TIMEOUT_SECONDS=180

# URL evaluator parallelism: 0 means unlimited.
MAX_URL_CONCURRENCY=0
# Candidate URLs are processed in fixed sequential batches.
URL_BATCH_SIZE=40

# Local VPN helper script + defaults file used by this repo.
VPN_START_SCRIPT=scripts/vpn_start.sh
VPN_DEFAULTS_FILE=scripts/vpn_defaults.sh
AUTO_START_VPN=true
VPN_OVPN_CONFIG=
VPN_DOCDB_HOST=
VPN_DOCDB_PORT=27017
VPN_REQUIRE_SPLIT_TUNNEL=true
VPN_REQUIRE_DOCDB_REACHABLE=true
VPN_LOG_DIR=.vpn_logs

# Pipeline controls
STRATEGY_COUNT=10
QUERIES_PER_STRATEGY=5
SERP_PAGES_PER_QUERY=2
RESULTS_PER_SERP_PAGE=10
MAX_INTERNAL_LINKS=12
MAX_LINK_DEPTH=1
MAX_SITE_GRAPH_VISITS=6
MAX_SITE_GRAPH_NODES=80
MAX_SITE_GRAPH_FRONTIER=8
MAX_SITEMAP_URLS=150
MAX_SITEMAP_FETCHES=6
REQUEST_TIMEOUT_SECONDS=20
PDF_INLINE_MAX_BYTES=8000000
HTTP_POOL_TIMEOUT_SECONDS=30
HTTP_MAX_CONNECTIONS=300
HTTP_MAX_KEEPALIVE_CONNECTIONS=100
FETCH_RETRY_ATTEMPTS=3
FETCH_RETRY_BASE_BACKOFF_SECONDS=0.5
LLM_MAX_RETRIES=2
